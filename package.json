{
  "name": "flow-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"SERVER,CLIENT\" --prefix-colors \"blue,green\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "setup": "npm install && cd server && npm install && cd ../client && npm install && echo \"\n✅ Setup complete! Run: npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
